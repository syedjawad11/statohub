---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Link from '../components/Link.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { routes, type ArticleId, type CategoryId } from '../lib/links';
import { organizationSchema, webSiteSchema } from '../lib/schema';

type CategoryEntry = CollectionEntry<'categories'>;

const site = Astro.site ?? Astro.url;
const homeJsonLd = [
  webSiteSchema(site),
  organizationSchema(site, { logo: '/apple-touch-icon.png' }),
];

const categoryEntries = await getCollection('categories');
const categoryById = new Map<CategoryId, CategoryEntry>(
  categoryEntries.map((entry: CategoryEntry) => [
    entry.id.replace(/\.[^.]+$/, '') as CategoryId,
    entry,
  ]),
);

const categoryCards = [
  {
    id: 'descriptive-statistics',
    fallbackTitle: 'Descriptive',
    fallbackDescription: 'Summarise and describe data: averages, spread, frequency, and shape.',
    guides: 24,
    calculators: 11,
    glyph: 'bars',
  },
  {
    id: 'probability-distributions',
    fallbackTitle: 'Probability',
    fallbackDescription: 'Distributions, expected value, and the rules of chance from the ground up.',
    guides: 19,
    calculators: 9,
    glyph: 'curve',
  },
  {
    id: 'regression-correlation',
    fallbackTitle: 'Regression',
    fallbackDescription: 'Correlation, lines of best fit, and reading relationships between variables.',
    guides: 14,
    calculators: 6,
    glyph: 'scatter',
  },
  {
    id: 'inferential-statistics',
    fallbackTitle: 'Inferential',
    fallbackDescription: 'Confidence intervals, hypothesis tests, and reasoning from sample to population.',
    guides: 21,
    calculators: 10,
    glyph: 'inference',
  },
  {
    id: 'foundations',
    fallbackTitle: 'Foundations',
    fallbackDescription: 'Notation, variables, and the vocabulary every other topic builds on.',
    guides: 12,
    calculators: 4,
    glyph: 'document',
  },
] satisfies Array<{
  id: CategoryId;
  fallbackTitle: string;
  fallbackDescription: string;
  guides: number;
  calculators: number;
  glyph: 'bars' | 'curve' | 'scatter' | 'inference' | 'document';
}>;

const calculatorTools = [
  { mark: 'xbar', title: 'Mean', detail: 'average of a dataset', route: routes.calculator('mean') },
  { mark: 'SD', title: 'Standard deviation', detail: 'spread around the mean', route: routes.calculator('standard-deviation') },
  { mark: 'f', title: 'Frequency table', detail: 'counts and proportions', route: routes.calculator('frequency-table') },
  { mark: '%', title: 'Percentile', detail: 'rank within data', route: routes.calculator('percentile') },
] satisfies Array<{ mark: string; title: string; detail: string; route: ReturnType<typeof routes.calculator> }>;

const recentGuides = [
  { id: 'frequency-table', category: 'Descriptive', title: 'Frequency Tables: How to Build & Read Them', meta: '15 min - Beginner - includes calculator' },
  { id: 'z-score', category: 'Inferential', title: 'What Is a Z-Score?', meta: '12 min - Beginner - includes calculator' },
  { id: 'probability-distribution', category: 'Probability', title: 'Probability Distribution, Plainly Explained', meta: '12 min - Beginner - includes calculator' },
  { id: 'correlation-vs-causation', category: 'Regression', title: 'Correlation vs Causation, Made Concrete', meta: '10 min - Beginner' },
] satisfies Array<{ id: ArticleId; category: string; title: string; meta: string }>;
---

<BaseLayout
  title="Statohub - Statistics Calculators & Plain-English Lessons"
  description="Every Statohub page pairs a plain-English explanation with a working calculator. Learn the method and get the number in the same place."
  canonicalPath={routes.home()}
  jsonLd={homeJsonLd}
>
  <section class="hero">
    <div>
      <div class="kicker"><span class="pill">Statistics, clearly</span><span class="eyebrow">Foundations -> Inference</span></div>
      <h1>Learn the concept.<br /><em>Compute</em> the answer.<br />On the same page.</h1>
      <p class="sub">
        Statohub is a study companion for statistics: plain-spoken guides paired with a working calculator on every topic, so understanding and answer never live apart.
      </p>
      <div class="hero-cta">
        <Link to={routes.categoryHub('descriptive-statistics')} class="btn btn-pine">Browse the guides</Link>
        <Link to={routes.calculatorsHub()} class="btn btn-ghost">Open the calculators</Link>
      </div>
      <div class="wedge-chips">
        <span class="wchip teach"><span class="b" aria-hidden="true"></span>Every page explains</span>
        <span class="wchip compute"><span class="b" aria-hidden="true"></span>Every page computes</span>
      </div>
    </div>
    <div class="hero-fig">
      <div class="cap"><span>Normal distribution</span><span>mu = 0 - sigma = 1</span></div>
      <svg viewBox="0 0 380 200" fill="none" aria-hidden="true">
        <line x1="20" y1="170" x2="360" y2="170" stroke="var(--line-2)" stroke-width="1"></line>
        <g stroke="var(--line)" stroke-width="1">
          <line x1="20" y1="40" x2="360" y2="40"></line><line x1="20" y1="90" x2="360" y2="90"></line><line x1="20" y1="130" x2="360" y2="130"></line>
        </g>
        <path d="M20 168 C 110 168, 150 30, 190 30 S 270 168, 360 168" stroke="var(--pine)" stroke-width="2.5"></path>
        <path d="M20 168 C 110 168, 150 30, 190 30 S 270 168, 360 168 L360 170 L20 170 Z" fill="var(--pine)" opacity=".10"></path>
        <line x1="190" y1="30" x2="190" y2="170" stroke="var(--clay)" stroke-width="1.5" stroke-dasharray="4 4"></line>
        <circle cx="190" cy="30" r="3.5" fill="var(--clay)"></circle>
      </svg>
      <div class="legend">
        <span><i style="background:var(--pine)"></i>density</span>
        <span><i style="background:var(--clay)"></i>mean</span>
      </div>
    </div>
  </section>

  <section class="home-section handbook-section">
    <div class="section-head">
      <div>
        <h2>The handbook</h2>
        <p class="lead">Six areas of statistics, each a growing shelf of guides with the tools to apply them.</p>
      </div>
      <Link to={routes.categoryHub('descriptive-statistics')} class="section-link">All topics -></Link>
    </div>
    <div class="catalog">
      {
        categoryCards.map((card) => {
          const entry = categoryById.get(card.id);
          const title = entry?.data.title ?? card.fallbackTitle;
          const description = entry?.data.description ?? card.fallbackDescription;

          return (
            <Link class="cat" to={routes.categoryHub(card.id)}>
              <span class="ico" aria-hidden="true">
                {card.glyph === 'bars' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19V5M4 19h16M8 16v-5M12 16V8M16 16v-10" /></svg>}
                {card.glyph === 'curve' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 17c4-9 14-9 18 0" /><circle cx="12" cy="6" r="2" /></svg>}
                {card.glyph === 'scatter' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 20 20 4" /><circle cx="7" cy="17" r="1.6" /><circle cx="12" cy="13" r="1.6" /><circle cx="16" cy="8" r="1.6" /></svg>}
                {card.glyph === 'inference' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3v18M5 12l7-4 7 4" /><circle cx="12" cy="3" r="1.5" /></svg>}
                {card.glyph === 'document' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 3h9l3 3v15H6z" /><path d="M9 9h6M9 13h6M9 17h3" /></svg>}
              </span>
              <h3>{title}</h3>
              <p>{description}</p>
              <div class="meta"><span><b>{card.guides}</b> guides</span><span><b>{card.calculators}</b> tools</span></div>
            </Link>
          );
        })
      }
      <Link class="cat" to={routes.calculatorsHub()}>
        <span class="ico calc-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="3" width="14" height="18" rx="2" /><path d="M8 7h8M8 11h2M12 11h2M8 15h2M12 15h2" /></svg></span>
        <h3>Calculators</h3>
        <p>Every tool on the site in one hub: fast, free, and explained.</p>
        <div class="meta"><span><b>40+</b> tools</span><span><b>all</b> free</span></div>
      </Link>
    </div>
  </section>

  <section class="band">
    <div>
      <span class="eyebrow">The Statohub difference</span>
      <h2>Tools that show their working</h2>
      <p>Most calculators give you a number and nothing else. Ours sit beside the explanation, so you can check the method as you go.</p>
      <Link to={routes.calculatorsHub()} class="btn btn-pine">Browse calculators</Link>
    </div>
    <div class="tool-grid">
      {calculatorTools.map((tool) => (
        <Link class="tool" to={tool.route}>
          <span class="t-ico" aria-hidden="true">{tool.mark}</span>
          <span><span class="t-name">{tool.title}</span><br /><span class="t-sub">{tool.detail}</span></span>
        </Link>
      ))}
    </div>
  </section>

  <section class="home-section recent-section">
    <div class="section-head"><div><h2>Recently published</h2></div><Link class="section-link" to={routes.article('frequency-table')}>All guides -></Link></div>
    <div class="pub-list">
      {recentGuides.map((guide, index) => (
        <Link class="pub" to={routes.article(guide.id)}>
          <span class="idx">{String(index + 1).padStart(2, '0')}</span>
          <div><span class="p-cat">{guide.category}</span><h4>{guide.title}</h4><span class="p-meta">{guide.meta}</span></div>
        </Link>
      ))}
    </div>
  </section>
</BaseLayout>