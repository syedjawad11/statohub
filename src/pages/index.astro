---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Link from '../components/Link.astro';
import StatCalc from '../components/StatCalc.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { routes, type CategoryId } from '../lib/links';

type CategoryEntry = CollectionEntry<'categories'>;

const categoryEntries = await getCollection('categories');
const categoryById = new Map<CategoryId, CategoryEntry>(
  categoryEntries.map((entry: CategoryEntry) => [
    entry.id.replace(/\.[^.]+$/, '') as CategoryId,
    entry,
  ]),
);

const categoryCards = [
  {
    id: 'descriptive-statistics',
    fallbackTitle: 'Descriptive Statistics',
    fallbackDescription: 'Mean, median, range, variance, percentiles - how to summarise a dataset in a single number.',
    guides: 24,
    calculators: 6,
    glyph: 'bars',
  },
  {
    id: 'probability-distributions',
    fallbackTitle: 'Probability & Distributions',
    fallbackDescription: 'From basic probability to the normal, binomial and Poisson - the shapes randomness takes.',
    guides: 19,
    calculators: 5,
    glyph: 'curve',
  },
  {
    id: 'combinatorics',
    fallbackTitle: 'Combinatorics',
    fallbackDescription: 'Permutations, combinations and factorials - counting the ways things can happen.',
    guides: 11,
    calculators: 4,
    glyph: 'blocks',
  },
  {
    id: 'regression-correlation',
    fallbackTitle: 'Regression & Correlation',
    fallbackDescription: 'Lines of best fit, r and r-squared, and what it really means for two things to move together.',
    guides: 14,
    calculators: 4,
    glyph: 'scatter',
  },
  {
    id: 'inferential-statistics',
    fallbackTitle: 'Inferential Statistics',
    fallbackDescription: 'Hypothesis tests, p-values, confidence intervals - drawing conclusions from samples.',
    guides: 21,
    calculators: 7,
    glyph: 'inference',
  },
  {
    id: 'foundations',
    fallbackTitle: 'Foundations',
    fallbackDescription: 'Notation, key terms and the big-picture map - the groundwork before everything else.',
    guides: 9,
    calculators: 2,
    glyph: 'document',
  },
] satisfies Array<{
  id: CategoryId;
  fallbackTitle: string;
  fallbackDescription: string;
  guides: number;
  calculators: number;
  glyph: 'bars' | 'curve' | 'blocks' | 'scatter' | 'inference' | 'document';
}>;

const calculatorChips = [
  {
    label: 'Descriptive',
    title: 'Standard Deviation',
    detail: 'Population & sample',
    route: routes.calculator('standard-deviation'),
  },
  {
    label: 'Descriptive',
    title: 'Mean',
    detail: 'Average of a dataset',
    route: routes.calculator('mean'),
  },
  {
    label: 'Descriptive',
    title: 'Range',
    detail: 'Minimum to maximum',
    route: routes.calculator('range'),
  },
];
---

<BaseLayout
  title="Statohub"
  description="Every Statohub page pairs a plain-English explanation with a working calculator. Learn the method and get the number in the same place."
  canonicalPath={routes.home()}
>
  <section class="home-hero">
    <p class="eyebrow">Statistics, taught and computed</p>
    <h1>Statistics you can read <em>and</em> run.</h1>
    <p class="home-lede">
      Every Statohub page does two jobs: a clear, example-led explanation of the concept,
      and a calculator that works the moment you need it.
    </p>
    <div class="home-cta-row">
      <Link to={routes.categoryHub('descriptive-statistics')} class="btn btn-primary">Start learning</Link>
      <Link to={routes.calculatorsHub()} class="btn">Jump to a calculator</Link>
    </div>

    <div class="fused-card">
      <div class="fused-side fused-teach">
        <span class="side-tag side-tag-teach"><span class="pip" aria-hidden="true"></span>The explanation</span>
        <h2>Standard deviation</h2>
        <p>
          It measures how spread out a set of numbers is around their mean. A small value
          means the data clusters tightly; a large value means it's scattered widely.
        </p>
        <p>For a full population you divide by <em>n</em>; for a sample, by <em>n-1</em>.</p>
        <span class="formula-chip">σ = √( Σ(xᵢ − μ)² / n )</span>
      </div>
      <div class="fused-side fused-compute">
        <span class="side-tag side-tag-compute"><span class="pip" aria-hidden="true"></span>The calculator</span>
        <div class="fused-calc-frame">
          <StatCalc slug="standard-deviation" variant="embed" />
        </div>
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Explore by topic</p>
        <h2>Six paths through statistics</h2>
      </div>
      <p>
        Each topic is a hub of guides and tools - start at the pillar and follow the links
        wherever your question leads.
      </p>
    </div>
    <div class="category-grid">
      {
        categoryCards.map((card) => {
          const entry = categoryById.get(card.id);
          const title = entry?.data.title ?? card.fallbackTitle;
          const description = entry?.data.description ?? card.fallbackDescription;

          return (
            <Link class="topic-card" to={routes.categoryHub(card.id)}>
              <div class="topic-glyph" aria-hidden="true">
                {card.glyph === 'bars' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                    <path d="M3 21h18" />
                    <rect x="4" y="11" width="3" height="7" />
                    <rect x="10.5" y="6" width="3" height="12" />
                    <rect x="17" y="14" width="3" height="4" />
                  </svg>
                )}
                {card.glyph === 'curve' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                    <path d="M3 19c4 0 4-12 9-12s5 12 9 12" />
                    <path d="M3 19h18" />
                  </svg>
                )}
                {card.glyph === 'blocks' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <rect x="3" y="3" width="8" height="8" rx="2" />
                    <rect x="13" y="13" width="8" height="8" rx="2" />
                    <circle cx="7" cy="7" r="1.3" fill="currentColor" stroke="none" />
                    <circle cx="17" cy="17" r="1.3" fill="currentColor" stroke="none" />
                    <path d="M11 7h3a2 2 0 0 1 2 2v2" stroke-linecap="round" />
                  </svg>
                )}
                {card.glyph === 'scatter' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                    <path d="M3 21h18M3 21V3" />
                    <path d="M4 18l16-11" />
                    <circle cx="7" cy="15" r="1.2" fill="currentColor" stroke="none" />
                    <circle cx="11" cy="13" r="1.2" fill="currentColor" stroke="none" />
                    <circle cx="14" cy="10" r="1.2" fill="currentColor" stroke="none" />
                    <circle cx="18" cy="8" r="1.2" fill="currentColor" stroke="none" />
                  </svg>
                )}
                {card.glyph === 'inference' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                    <path d="M3 18c4 0 4-11 9-11s5 11 9 11" />
                    <path d="M3 18h18" />
                    <path d="M16 18c0-3 .8-6 2-7.5" opacity=".4" />
                    <path d="M16.5 18l1.6-5.5" />
                  </svg>
                )}
                {card.glyph === 'document' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 4h9l5 5v11a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1z" />
                    <path d="M14 4v5h5" />
                    <path d="M8 13h6M8 16h4" opacity=".6" />
                  </svg>
                )}
              </div>
              <h3>{title}</h3>
              <p>{description}</p>
              <div class="topic-meta">
                <span><b>{card.guides}</b> guides</span>
                <span><b>{card.calculators}</b> calculators</span>
              </div>
            </Link>
          );
        })
      }
    </div>
  </section>

  <section class="home-section home-section-alt">
    <div class="section-head">
      <div>
        <p class="eyebrow">Tools</p>
        <h2>Popular calculators</h2>
      </div>
      <p>Standalone tools for when you already know the concept and just need the answer.</p>
    </div>
    <div class="calculator-strip">
      {
        calculatorChips.map((chip) => (
          <Link class="calculator-chip" to={chip.route}>
            <div class="chip-tag"><span class="pip" aria-hidden="true"></span>{chip.label}</div>
            <h3>{chip.title}</h3>
            <span>{chip.detail}</span>
          </Link>
        ))
      }
    </div>
  </section>

  <section class="home-section how-section">
    <div>
      <p class="eyebrow">The Statohub idea</p>
      <h2>Most sites teach <em>or</em> compute. We do both, on the same page.</h2>
      <p>
        Calculator sites give you a number with no understanding. Textbook sites explain
        without a tool in sight. Statohub puts the explanation and the calculator side by
        side - so the method makes sense and the answer is one click away.
      </p>
    </div>
    <div class="steps-list">
      <div class="home-step">
        <span>1</span>
        <div>
          <h3>Read the concept</h3>
          <p>A plain-English explanation with a worked example - no wall of notation.</p>
        </div>
      </div>
      <div class="home-step">
        <span>2</span>
        <div>
          <h3>Run your own numbers</h3>
          <p>The matching calculator is embedded right there. Swap in your data and see it work.</p>
        </div>
      </div>
      <div class="home-step">
        <span>3</span>
        <div>
          <h3>Follow the thread</h3>
          <p>Every page links to the next idea, so one question naturally leads to the next.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
