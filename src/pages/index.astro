---
import BaseLayout from '../layouts/BaseLayout.astro';
import Link from '../components/Link.astro';
import type { RouteRef } from '../lib/links';

const calculatorsHubRoute = { kind: 'calculatorsHub' } satisfies RouteRef;
---

<BaseLayout
  title="Statohub"
  description="Statistics education and calculator tools for clear, practical learning."
>
  <section class="max-w-3xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-teal-700 dark:text-teal-300">
      Statistics education
    </p>
    <h1 class="mt-3 text-4xl font-bold tracking-normal text-slate-950 dark:text-white sm:text-5xl">
      Learn statistics with focused guides and calculators.
    </h1>
    <p class="mt-5 text-lg leading-8 text-slate-700 dark:text-slate-300">
      Statohub is being built as a fast, static statistics reference with flat
      trailing-slash URLs and calculator pages that work cleanly on Cloudflare Pages.
    </p>
    <p class="mt-8">
      <Link to={calculatorsHubRoute} class="font-medium">View calculators</Link>
    </p>
  </section>
</BaseLayout>
