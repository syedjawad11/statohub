---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Normal Distribution | Statohub"
  description="Sample route proving Statohub directory output and trailing-slash routing."
>
  <article class="max-w-3xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-teal-700 dark:text-teal-300">
      Proof route
    </p>
    <h1 class="mt-3 text-4xl font-bold tracking-normal text-slate-950 dark:text-white sm:text-5xl">
      Normal distribution
    </h1>
    <p class="mt-5 text-lg leading-8 text-slate-700 dark:text-slate-300">
      This temporary page proves that the site builds folder-based routes to
      <code class="rounded bg-slate-200 px-1.5 py-0.5 text-sm dark:bg-slate-800">dist/normal-distribution/index.html</code>.
    </p>
    <p class="mt-8">
      <a href="/" class="font-medium">Back to Statohub</a>
    </p>
  </article>
</BaseLayout>
