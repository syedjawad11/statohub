---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import StatCalc from '../../../components/StatCalc.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';

type CalculatorEntry = CollectionEntry<'calculators'>;
type CalculatorData = CalculatorEntry['data'];

export async function getStaticPaths() {
  const calculators = await getCollection('calculators');

  return calculators
    .filter((entry: CalculatorEntry) => entry.data.standalone !== false)
    .map((entry: CalculatorEntry) => ({
      params: { slug: entry.id },
      props: { calc: entry.data, slug: entry.id },
    }));
}

interface Props {
  calc: CalculatorData;
  slug: string;
}

const { calc, slug } = Astro.props as Props;
---

<BaseLayout title={`${calc.title} | Statohub`} description={calc.description}>
  <article class="max-w-3xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-teal-700 dark:text-teal-300">
      Calculator
    </p>
    <h1 class="mt-3 text-4xl font-bold tracking-normal text-slate-950 dark:text-white sm:text-5xl">
      {calc.title}
    </h1>
    <p class="mt-5 text-lg leading-8 text-slate-700 dark:text-slate-300">
      {calc.description}
    </p>
    <div class="mt-8">
      <StatCalc slug={slug} variant="page" />
    </div>
  </article>
</BaseLayout>
