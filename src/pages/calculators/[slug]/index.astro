---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import StatCalc from '../../../components/StatCalc.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { routes } from '../../../lib/links';
import { softwareApplicationSchema, type BreadcrumbItem } from '../../../lib/schema';

type CalculatorEntry = CollectionEntry<'calculators'>;
type CalculatorData = CalculatorEntry['data'];
type CalculatorId = CalculatorEntry['id'];

export async function getStaticPaths() {
  const calculators = await getCollection('calculators');

  return calculators
    .filter((entry: CalculatorEntry) => entry.data.standalone !== false)
    .map((entry: CalculatorEntry) => ({
      params: { slug: entry.id },
      props: { calc: entry.data, slug: entry.id },
    }));
}

interface Props {
  calc: CalculatorData;
  slug: CalculatorId;
}

const { calc, slug } = Astro.props as Props;

// Optional short teaching block (intro + how-to + worked example + FAQ) rendered
// below the tool. Source: src/content/calculator-content/{slug}.mdx, draft:false.
type TeachingEntry = CollectionEntry<'calculator-content'>;
const teachingEntries = await getCollection('calculator-content');
const teaching = teachingEntries.find(
  (entry: TeachingEntry) => entry.id.replace(/\.[^.]+$/, '') === slug && !entry.data.draft,
);
let Teaching: Awaited<ReturnType<TeachingEntry['render']>>['Content'] | undefined;
if (teaching) {
  const rendered = await teaching.render();
  Teaching = rendered.Content;
}

const breadcrumbs: BreadcrumbItem[] = [
  { label: 'Home', route: routes.home() },
  { label: 'Calculators', route: routes.calculatorsHub() },
  { label: calc.title, route: routes.calculator(slug) },
];
const site = Astro.site ?? Astro.url;
const calculatorSchema = softwareApplicationSchema(
  {
    id: slug,
    name: calc.title,
    description: calc.description,
  },
  site,
);
---

<BaseLayout
  title={`${calc.title} | Statohub`}
  description={calc.description}
  canonicalPath={routes.calculator(slug)}
  breadcrumbs={breadcrumbs}
  jsonLd={[calculatorSchema]}
>
  <article class="max-w-3xl">
    <p class="page-kicker">Calculator</p>
    <h1 class="page-title">{calc.title}</h1>
    <p class="page-lede">{calc.description}</p>
    <div class="mt-8">
      <StatCalc slug={slug} variant="page" />
    </div>
    {Teaching && (
      <div class="article-prose calc-teaching">
        <Teaching />
      </div>
    )}
  </article>
</BaseLayout>
