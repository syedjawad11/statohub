---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Link from '../../components/Link.astro';
import StatCalc from '../../components/StatCalc.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { routes, type RouteRef } from '../../lib/links';
import type { BreadcrumbItem } from '../../lib/schema';

type CalculatorEntry = CollectionEntry<'calculators'>;

const calculators = (await getCollection('calculators'))
  .filter((entry: CalculatorEntry) => entry.data.standalone !== false)
  .sort((a: CalculatorEntry, b: CalculatorEntry) => a.data.title.localeCompare(b.data.title));

const calculatorRoute = (id: CalculatorEntry['id']) => ({ kind: 'calculator', id }) satisfies RouteRef;
const breadcrumbs: BreadcrumbItem[] = [
  { label: 'Home', route: routes.home() },
  { label: 'Calculators', route: routes.calculatorsHub() },
];
---

<BaseLayout
  title="Calculators | Statohub"
  description="Statistics calculators for common descriptive statistics workflows."
  canonicalPath={routes.calculatorsHub()}
  breadcrumbs={breadcrumbs}
>
  <section class="max-w-3xl">
    <p class="page-kicker">Calculators</p>
    <h1 class="page-title">Statistics calculators</h1>
    <p class="page-lede">
      Use standalone tools for focused calculations, or try embedded examples inline.
    </p>

    <ul class="mt-8 grid gap-3 sm:grid-cols-2">
      {
        calculators.map((entry: CalculatorEntry) => (
          <li>
            <Link class="card-link" to={calculatorRoute(entry.id)}>
              <span class="eyebrow text-teal">Tool</span>
              <span class="mt-2 block font-serif text-xl font-semibold text-ink">{entry.data.title}</span>
              <span class="mt-1 block text-sm text-ink-soft">{entry.data.description}</span>
            </Link>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mt-12 grid gap-6 lg:grid-cols-2">
    <StatCalc slug="standard-deviation" variant="embed" />
    <StatCalc slug="median" variant="embed" />
  </section>
</BaseLayout>
