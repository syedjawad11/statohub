---
import BaseLayout from '../layouts/BaseLayout.astro';
import Link from '../components/Link.astro';
import { routes } from '../lib/links';

const homeRoute = routes.home();
const calculatorsHubRoute = routes.calculatorsHub();
---

<BaseLayout
  title="Page not found - Statohub"
  description="The page you were looking for does not exist."
  noindex={true}
>
  <section class="max-w-3xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-teal-700 dark:text-teal-300">
      404
    </p>
    <h1 class="mt-3 text-4xl font-bold tracking-normal text-slate-950 dark:text-white sm:text-5xl">
      This page does not exist.
    </h1>
    <p class="mt-5 text-lg leading-8 text-slate-700 dark:text-slate-300">
      The page you were looking for may have moved or never existed. Try the
      home page or browse the calculators.
    </p>
    <p class="mt-8 flex gap-6">
      <Link to={homeRoute} class="font-medium">Go home</Link>
      <Link to={calculatorsHubRoute} class="font-medium">View calculators</Link>
    </p>
  </section>
</BaseLayout>
