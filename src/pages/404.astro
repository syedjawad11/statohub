---
import BaseLayout from '../layouts/BaseLayout.astro';
import Link from '../components/Link.astro';
import { routes } from '../lib/links';

const homeRoute = routes.home();
const calculatorsHubRoute = routes.calculatorsHub();
---

<BaseLayout
  title="Page not found - Statohub"
  description="The page you were looking for does not exist."
  noindex={true}
>
  <section class="max-w-3xl">
    <p class="page-kicker">404</p>
    <h1 class="page-title">This page does not exist.</h1>
    <p class="page-lede">
      The page you were looking for may have moved or never existed. Try the
      home page or browse the calculators.
    </p>
    <p class="mt-8 flex flex-wrap gap-3">
      <Link to={homeRoute} class="btn">Go home</Link>
      <Link to={calculatorsHubRoute} class="btn btn-primary">View calculators</Link>
    </p>
  </section>
</BaseLayout>
