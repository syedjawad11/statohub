---
import { getCollection, getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import CategoryLayout from '../../layouts/CategoryLayout.astro';
import type { ArticleId, CalculatorId, CategoryId } from '../../lib/links';

type ArticleEntry = CollectionEntry<'articles'>;
type CategoryEntry = CollectionEntry<'categories'>;
type ArticleHeading = Awaited<ReturnType<ArticleEntry['render']>>['headings'][number];
type RelatedRef = ArticleEntry['data']['related'][number];

export async function getStaticPaths() {
  const articleId = (entry: ArticleEntry) => entry.id.replace(/\.[^.]+$/, '') as ArticleId;
  const categoryId = (entry: CategoryEntry) => entry.id.replace(/\.[^.]+$/, '') as CategoryId;
  const articles = (await getCollection('articles')).filter((entry: ArticleEntry) => !entry.data.draft);
  const categories = await getCollection('categories');

  const articleIds = new Set(articles.map(articleId));
  const collisions = categories
    .map(categoryId)
    .filter((id: CategoryId) => articleIds.has(id as unknown as ArticleId));

  if (collisions.length > 0) {
    throw new Error(`Root route slug collision between articles and categories: ${collisions.join(', ')}`);
  }

  // Articles and category hubs share the flat /{slug}/ URL space, so this
  // single root route owns both collections.
  return [
    ...articles.map((entry: ArticleEntry) => ({
      params: { slug: articleId(entry) },
      props: { kind: 'article' as const, entry, slug: articleId(entry) },
    })),
    ...categories.map((entry: CategoryEntry) => ({
      params: { slug: categoryId(entry) },
      props: { kind: 'category' as const, entry, slug: categoryId(entry) },
    })),
  ];
}

type Props =
  | { kind: 'article'; entry: ArticleEntry; slug: ArticleId }
  | { kind: 'category'; entry: CategoryEntry; slug: CategoryId };

const props = Astro.props as Props;

let Content: Awaited<ReturnType<ArticleEntry['render']>>['Content'] | undefined;
let headings: Awaited<ReturnType<ArticleEntry['render']>>['headings'] = [];
let category:
  | {
      id: CategoryId;
      title: string;
    }
  | undefined;
let hasCalculator = false;
let calculatorAnchor: string | undefined;
let readingTime: string | undefined;
let relatedArticles:
  | {
      id: ArticleId;
      title: string;
      description: string;
    }[]
  | undefined;
let relatedCalculator:
  | {
      id: CalculatorId;
      title: string;
      description: string;
      standalone: boolean;
    }
  | undefined;

if (props.kind === 'article') {
  const rendered = await props.entry.render();
  Content = rendered.Content;
  headings = rendered.headings;
  const categoryEntry = await getEntry(props.entry.data.category);
  const categoryId = props.entry.data.category.id as CategoryId;
  const words = props.entry.body.trim().split(/\s+/).filter(Boolean).length;
  const minutes = Math.max(1, Math.ceil(words / 225));
  const calculatorHeading = headings.find(
    (heading: ArticleHeading) => heading.depth === 2 && /calculator/i.test(`${heading.text} ${heading.slug}`),
  );

  hasCalculator = Boolean(props.entry.data.calculator);
  calculatorAnchor = calculatorHeading?.slug;
  readingTime = `${minutes} min read`;
  relatedArticles = (
    await Promise.all((props.entry.data.related ?? []).map((ref: RelatedRef) => getEntry(ref)))
  )
    .filter((entry): entry is ArticleEntry => Boolean(entry) && !entry.data.draft)
    .map((entry) => ({
      id: entry.id.replace(/\.[^.]+$/, '') as ArticleId,
      title: entry.data.title,
      description: entry.data.description,
    }));
  category = {
    id: categoryId,
    title: categoryEntry?.data.title ?? categoryId,
  };

  if (props.entry.data.calculator) {
    const calculator = await getEntry(props.entry.data.calculator);
    if (calculator) {
      relatedCalculator = {
        id: calculator.id.replace(/\.[^.]+$/, '') as CalculatorId,
        title: calculator.data.title,
        description: calculator.data.description,
        standalone: calculator.data.standalone !== false,
      };
    }
  }
}
---

{
  props.kind === 'article' && Content && category ? (
    <ArticleLayout
      article={props.entry.data}
      slug={props.slug}
      category={category}
      headings={headings}
      hasCalculator={hasCalculator}
      calculatorAnchor={calculatorAnchor}
      readingTime={readingTime}
      relatedArticles={relatedArticles}
      relatedCalculator={relatedCalculator}
    >
      <Content />
    </ArticleLayout>
  ) : (
    <CategoryLayout category={(props as Extract<Props, { kind: 'category' }>).entry.data} slug={(props as Extract<Props, { kind: 'category' }>).slug} />
  )
}
