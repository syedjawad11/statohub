---
import { getCollection, getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import type { ArticleId } from '../../lib/links';

type ArticleEntry = CollectionEntry<'articles'>;

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const articleId = (entry: ArticleEntry) => entry.id.replace(/\.[^.]+$/, '') as ArticleId;

  // Future category hubs also need root /{slug}/ URLs; fold them into this route
  // instead of creating a second root [slug] route.
  return articles
    .filter((entry: ArticleEntry) => !entry.data.draft)
    .map((entry: ArticleEntry) => ({
      params: { slug: articleId(entry) },
      props: { entry, slug: articleId(entry) },
    }));
}

interface Props {
  entry: ArticleEntry;
  slug: ArticleId;
}

const { entry, slug } = Astro.props as Props;
const { Content } = await entry.render();
const category = await getEntry(entry.data.category);
---

<ArticleLayout article={entry.data} slug={slug} categoryTitle={category?.data.title}>
  <Content />
</ArticleLayout>
