---
import type { CollectionEntry } from 'astro:content';
import Link from '../components/Link.astro';
import BaseLayout from './BaseLayout.astro';
import { routes, type ArticleId, type CalculatorId, type CategoryId } from '../lib/links';
import { articleSchema, organizationSchema, webSiteSchema, type BreadcrumbItem } from '../lib/schema';

type ArticleData = CollectionEntry<'articles'>['data'];

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface RelatedArticle {
  id: ArticleId;
  title: string;
  description: string;
}

interface RelatedCalculator {
  id: CalculatorId;
  title: string;
  description: string;
  standalone: boolean;
}

interface Props {
  article: ArticleData;
  slug: ArticleId;
  category: {
    id: CategoryId;
    title: string;
  };
  headings: Heading[];
  hasCalculator: boolean;
  calculatorAnchor?: string;
  readingTime?: string;
  level?: string;
  relatedArticles?: RelatedArticle[];
  relatedCalculator?: RelatedCalculator;
}

const {
  article,
  slug,
  category,
  headings,
  hasCalculator,
  calculatorAnchor,
  readingTime,
  level = 'Beginner',
  relatedArticles = [],
  relatedCalculator,
} = Astro.props as Props;

const tocItems = headings.filter((heading) => heading.depth === 2);
const updatedDate = article.updatedDate ?? article.pubDate;
const formattedDate = updatedDate
  ? new Intl.DateTimeFormat('en', { month: 'short', year: 'numeric' }).format(updatedDate)
  : undefined;
const keepGoingItems = [
  ...relatedArticles.map((item) => ({
    kind: 'Guide' as const,
    title: item.title,
    description: item.description,
    route: routes.article(item.id),
  })),
  ...(relatedCalculator?.standalone
    ? [
        {
          kind: 'Calculator' as const,
          title: relatedCalculator.title,
          description: relatedCalculator.description,
          route: routes.calculator(relatedCalculator.id),
        },
      ]
    : []),
];

const breadcrumbs: BreadcrumbItem[] = [
  { label: 'Home', route: routes.home() },
  { label: category.title, route: routes.categoryHub(category.id) },
  { label: article.title, route: routes.article(slug) },
];
const site = Astro.site ?? Astro.url;
const schema = articleSchema(
  {
    id: slug,
    headline: article.title,
    description: article.description,
    datePublished: article.pubDate,
    dateModified: article.updatedDate ?? article.pubDate,
    image: article.ogImage,
  },
  site,
);
const articleJsonLd = [
  schema,
  webSiteSchema(site),
  organizationSchema(site, { logo: '/apple-touch-icon.png' }),
];
---

<BaseLayout
  title={`${article.title} | Statohub`}
  description={article.description}
  canonicalPath={routes.article(slug)}
  ogType="article"
  ogImage={article.ogImage}
  breadcrumbs={breadcrumbs}
  showBreadcrumbs={false}
  jsonLd={articleJsonLd}
>
  <div class="reading-progress" id="reading-progress" aria-hidden="true"></div>

  <nav class="crumb" aria-label="Breadcrumb">
    <Link to={routes.home()}>Home</Link>
    <span class="s" aria-hidden="true">/</span>
    <Link to={routes.categoryHub(category.id)}>{category.title}</Link>
    <span class="s" aria-hidden="true">/</span>
    <span>{article.title}</span>
  </nav>

  <div class="article-grid article-shell">
    <article class="article-column">
      <header class="article-head">
        <div class="eyebrow">
          <span class="pill">{category.title}</span>
          {level && <><span class="sep" aria-hidden="true"></span>{level}</>}
          {hasCalculator && <><span class="sep" aria-hidden="true"></span>Includes calculator</>}
        </div>
        <h1 class="article-title">{article.h1 ?? article.title}</h1>
        <p class="article-standfirst">{article.description}</p>
        <div class="meta-row article-meta">
          {readingTime && <span class="m"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" /></svg>{readingTime}</span>}
          {hasCalculator && <span class="m"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 19V5M4 19h16M8 16v-5M12 16V8M16 16v-9" /></svg>1 calculator</span>}
          {formattedDate && <span class="m"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 20a8 8 0 1 0-8-8" /><path d="M12 8v4l3 2" /></svg>Updated {formattedDate}</span>}
        </div>
      </header>

      <svg class="divider article-divider" viewBox="0 0 1000 24" preserveAspectRatio="none" fill="none" aria-hidden="true">
        <path d="M0 22 C 180 22, 240 4, 420 4 S 640 22, 1000 22" stroke="currentColor" stroke-width="1.5"></path>
        <path d="M0 22 C 180 22, 240 4, 420 4 S 640 22, 1000 22 L1000 24 L0 24 Z" fill="currentColor" opacity=".18"></path>
      </svg>

      <div class="article-body article-prose">
        <slot />
      </div>

      {keepGoingItems.length > 0 && (
        <section class="related related-section">
          <h3>Keep going</h3>
          <div class="rel-grid related-grid">
            {
              keepGoingItems.map((item) => (
                <Link class="rel related-card" to={item.route}>
                  <span class="p-cat related-tag">{item.kind}</span>
                  <h4>{item.title}</h4>
                  <p>{item.description}</p>
                </Link>
              ))
            }
          </div>
        </section>
      )}
    </article>

    <aside class="aside article-rail article-rail-right">
      {tocItems.length > 0 && (
        <>
          <p class="aside-label toc-label">On this page</p>
          <nav class="article-toc" id="article-toc" aria-label="On this page">
            <ul class="toc">
              {
                tocItems.map((heading, index) => (
                  <li><a href={`#${heading.slug}`} class:list={[index === 0 && 'active']}>{heading.text}</a></li>
                ))
              }
            </ul>
          </nav>
        </>
      )}
      {hasCalculator && calculatorAnchor && (
        <div class="aside-tool">
          <p class="t">Article calculator</p>
          <p>Jump to the embedded calculator and run the example with your own numbers.</p>
          <a href={`#${calculatorAnchor}`} class="btn btn-ghost toc-jump">Jump to calculator</a>
        </div>
      )}
    </aside>
  </div>

  <script is:inline>
    (() => {
      const progress = document.getElementById('reading-progress');
      const tocLinks = Array.from(document.querySelectorAll('.article-toc a[href^="#"]'));
      const sections = tocLinks
        .map((link) => {
          const id = link.getAttribute('href')?.slice(1);
          return id ? document.getElementById(id) : null;
        })
        .filter(Boolean);
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const updateProgress = () => {
        if (!progress) return;
        const scrollTop = window.scrollY || document.documentElement.scrollTop;
        const max = document.documentElement.scrollHeight - window.innerHeight;
        const pct = max > 0 ? Math.min(1, Math.max(0, scrollTop / max)) : 0;
        progress.style.width = `${pct * 100}%`;
      };

      const setActive = (id) => {
        tocLinks.forEach((link) => {
          link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
        });
      };

      if ('IntersectionObserver' in window && sections.length > 0) {
        const observer = new IntersectionObserver(
          (entries) => {
            const visible = entries
              .filter((entry) => entry.isIntersecting)
              .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];
            if (visible?.target?.id) setActive(visible.target.id);
          },
          { rootMargin: '-18% 0px -66% 0px', threshold: reduceMotion ? 0 : 0.01 },
        );
        sections.forEach((section) => observer.observe(section));
      }

      window.addEventListener('scroll', updateProgress, { passive: true });
      window.addEventListener('resize', updateProgress, { passive: true });
      updateProgress();
    })();
  </script>
</BaseLayout>