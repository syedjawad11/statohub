---
import '../styles/global.css';
import Link from '../components/Link.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Canonical from '../components/seo/Canonical.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import Meta from '../components/seo/Meta.astro';
import { routes, url, type RouteRef } from '../lib/links';
import { breadcrumbList, type BreadcrumbItem } from '../lib/schema';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: RouteRef;
  ogType?: 'website' | 'article';
  ogImage?: string;
  breadcrumbs?: BreadcrumbItem[];
  showBreadcrumbs?: boolean;
  jsonLd?: object[];
  noindex?: boolean;
}

const {
  title = 'Statohub',
  description = 'Statistics education and calculator tools.',
  canonicalPath,
  ogType = 'website',
  ogImage = '/og-default.png',
  breadcrumbs,
  showBreadcrumbs = true,
  jsonLd = [],
  noindex = false,
} = Astro.props;

const site = Astro.site ?? Astro.url;
const canonical = new URL(canonicalPath ? url(canonicalPath) : Astro.url.pathname, site);
canonical.search = '';
canonical.hash = '';

if (!canonical.pathname.endsWith('/')) {
  canonical.pathname = `${canonical.pathname}/`;
}

const schemas = breadcrumbs
  ? [breadcrumbList(breadcrumbs, site), ...jsonLd]
  : jsonLd;

const navLinks = [
  { label: 'Foundations', route: routes.categoryHub('foundations') },
  { label: 'Descriptive', route: routes.categoryHub('descriptive-statistics') },
  { label: 'Probability', route: routes.categoryHub('probability-distributions') },
  { label: 'Regression', route: routes.categoryHub('regression-correlation') },
  { label: 'Inferential', route: routes.categoryHub('inferential-statistics') },
  { label: 'Calculators', route: routes.calculatorsHub() },
];

const footerTopics = [
  { label: 'Descriptive', route: routes.categoryHub('descriptive-statistics') },
  { label: 'Probability', route: routes.categoryHub('probability-distributions') },
  { label: 'Regression', route: routes.categoryHub('regression-correlation') },
  { label: 'Inferential', route: routes.categoryHub('inferential-statistics') },
  { label: 'Foundations', route: routes.categoryHub('foundations') },
];

const footerCalculators = [
  { label: 'Standard deviation', route: routes.calculator('standard-deviation') },
  { label: 'Mean', route: routes.calculator('mean') },
  { label: 'Range', route: routes.calculator('range') },
  { label: 'All tools', route: routes.calculatorsHub() },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <Meta
      title={title}
      description={description}
      canonicalUrl={canonical.href}
      ogType={ogType}
      ogImage={ogImage}
    />
    <Canonical canonicalPath={canonicalPath ? url(canonicalPath) : undefined} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    {schemas.map((schema) => <JsonLd schema={schema} />)}
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const useDark = stored ? stored === 'dark' : prefersDark;
        document.documentElement.classList.toggle('dark', useDark);
      })();
    </script>
  </head>
  <body>
    <header class="topbar">
      <div class="site-wrap topbar-inner">
        <Link to={routes.home()} class="brand" aria-label="Statohub home">
          <span class="brand-dot" aria-hidden="true"></span>
          Statohub
        </Link>
        <nav class="nav-links" aria-label="Primary navigation">
          {navLinks.map((item) => <Link to={item.route} class="nav-link">{item.label}</Link>)}
        </nav>
        <span class="nav-spacer"></span>
        <button
          id="theme-toggle"
          type="button"
          class="toggle icon-btn"
          aria-label="Toggle dark mode"
          aria-pressed="false"
          title="Toggle theme"
        >
          <svg class="sun" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2M12 20v2M4 12H2M22 12h-2M5 5l1.5 1.5M17.5 17.5L19 19M5 19l1.5-1.5M17.5 6.5L19 5"></path>
          </svg>
          <svg class="moon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.5 6.5 0 0 0 9.8 9.8Z"></path>
          </svg>
        </button>
        <Link to={routes.calculatorsHub()} class="btn btn-pine nav-cta">Browse calculators</Link>
        <button
          id="menu-toggle"
          type="button"
          class="btn icon-btn menu-toggle"
          aria-label="Menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M3 6h18M3 12h18M3 18h18"></path>
          </svg>
        </button>
      </div>
      <div id="mobile-menu" class="mobile-panel site-wrap" data-open="false">
        <nav aria-label="Mobile navigation">
          {navLinks.map((item) => <Link to={item.route}>{item.label}</Link>)}
          <Link to={routes.calculatorsHub()}>Browse calculators</Link>
        </nav>
      </div>
    </header>
    <main class="site-main">
      <div class="site-wrap">
        {showBreadcrumbs && breadcrumbs && <Breadcrumbs items={breadcrumbs} />}
        <slot />
      </div>
    </main>
    <footer class="foot">
      <div class="site-wrap">
        <div class="foot-grid foot-inner">
          <div class="foot-brand">
            <Link to={routes.home()} class="brand">
              <span class="brand-dot" aria-hidden="true"></span>
              Statohub
            </Link>
            <p>Statistics education and calculator tools for clear, practical learning.</p>
          </div>
          <div>
            <h5>Topics</h5>
            {footerTopics.map((item) => <Link to={item.route}>{item.label}</Link>)}
          </div>
          <div>
            <h5>Calculators</h5>
            {footerCalculators.map((item) => <Link to={item.route}>{item.label}</Link>)}
          </div>
          <div>
            <h5>Site</h5>
            <Link to={routes.about()}>About</Link>
            <Link to={routes.privacyCookiePolicy()}>Privacy & Cookies</Link>
            <Link to={routes.categoryHub('foundations')}>Foundations</Link>
            <a href="/sitemap.xml">Sitemap</a>
          </div>
        </div>
        <div class="foot-bottom">
          <span>&copy; 2026 Statohub</span>
          <span class="font-mono">Built static - fast - flat URLs</span>
        </div>
      </div>
    </footer>
    <script is:inline>
      (() => {
        const themeButton = document.getElementById('theme-toggle');
        const menuButton = document.getElementById('menu-toggle');
        const menu = document.getElementById('mobile-menu');

        const syncPressed = () => {
          themeButton?.setAttribute(
            'aria-pressed',
            String(document.documentElement.classList.contains('dark')),
          );
        };

        themeButton?.addEventListener('click', () => {
          const nextIsDark = !document.documentElement.classList.contains('dark');
          document.documentElement.classList.toggle('dark', nextIsDark);
          localStorage.setItem('theme', nextIsDark ? 'dark' : 'light');
          syncPressed();
        });

        menuButton?.addEventListener('click', () => {
          const nextOpen = menu?.dataset.open !== 'true';
          if (menu) menu.dataset.open = String(nextOpen);
          menuButton.setAttribute('aria-expanded', String(nextOpen));
        });

        syncPressed();
      })();
    </script>
  </body>
</html>
