---
import { getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  slug: string;
  variant?: 'page' | 'embed';
}

const { slug, variant = 'embed' } = Astro.props;
const entry = await getEntry('calculators', slug);

if (!entry) {
  throw new Error(`Calculator not found: ${slug}`);
}

type CalculatorData = CollectionEntry<'calculators'>['data'];
type CalculatorInput = CalculatorData['inputs'][number];

const calc = entry.data as CalculatorData;
const instanceId = `statcalc-${slug}-${Math.random().toString(36).slice(2)}`;
const configId = `${instanceId}-config`;
const resultId = `${instanceId}-results`;
const titleId = `${instanceId}-title`;
const isPage = variant === 'page';

const config = {
  engine: calc.engine,
  inputs: calc.inputs,
  precision: calc.precision,
  resultLabel: calc.resultLabel,
  outputLabels: calc.outputLabels ?? {},
  chart: calc.chart,
};

const rootClass = isPage
  ? 'rounded-md border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900 sm:p-6'
  : 'rounded-md border border-slate-200 bg-white p-4 dark:border-slate-800 dark:bg-slate-900';
---

<section
  id={instanceId}
  class={rootClass}
  data-statcalc
  data-config-id={configId}
  aria-labelledby={titleId}
>
  <div class={isPage ? 'mb-6' : 'mb-4'}>
    <p class="text-sm font-semibold uppercase tracking-wide text-teal-700 dark:text-teal-300">
      Calculator
    </p>
    <h2 id={titleId} class={isPage ? 'mt-2 text-2xl font-bold text-slate-950 dark:text-white' : 'mt-2 text-xl font-semibold text-slate-950 dark:text-white'}>
      {calc.title}
    </h2>
    {isPage && <p class="mt-3 text-base leading-7 text-slate-700 dark:text-slate-300">{calc.description}</p>}
  </div>

  <form class="space-y-4" data-statcalc-form>
    {
      calc.inputs.map((input: CalculatorInput) => {
        const fieldId = `${instanceId}-${input.name}`;

        return (
          <div>
            <label for={fieldId} class="block text-sm font-medium text-slate-800 dark:text-slate-100">
              {input.label}
            </label>
            {input.type === 'numberList' ? (
              <textarea
                id={fieldId}
                name={input.name}
                rows="5"
                placeholder={input.placeholder ?? '2, 4, 4, 4, 5, 5, 7, 9'}
                data-input-type={input.type}
                class="mt-2 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-base text-slate-950 shadow-sm focus:border-teal-600 focus:outline-none focus:ring-2 focus:ring-teal-600/25 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:focus:border-teal-400 dark:focus:ring-teal-400/25"
              >
                {input.default ?? ''}
              </textarea>
            ) : (
              <input
                id={fieldId}
                name={input.name}
                type="number"
                inputmode="decimal"
                value={input.default ?? ''}
                placeholder={input.placeholder}
                data-input-type={input.type}
                class="mt-2 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-base text-slate-950 shadow-sm focus:border-teal-600 focus:outline-none focus:ring-2 focus:ring-teal-600/25 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:focus:border-teal-400 dark:focus:ring-teal-400/25"
              />
            )}
          </div>
        );
      })
    }

    <button
      type="submit"
      class="inline-flex items-center rounded-md bg-teal-700 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-teal-800 focus:outline-none focus:ring-2 focus:ring-teal-600 focus:ring-offset-2 focus:ring-offset-white dark:bg-teal-500 dark:text-slate-950 dark:hover:bg-teal-400 dark:focus:ring-teal-300 dark:focus:ring-offset-slate-900"
    >
      Compute
    </button>
  </form>

  <div
    id={resultId}
    class="mt-5 rounded-md border border-slate-200 bg-slate-50 p-4 text-sm text-slate-800 dark:border-slate-800 dark:bg-slate-950 dark:text-slate-100"
    data-statcalc-results
    aria-live="polite"
  >
    Enter values and compute the result.
  </div>

  <!-- Chart seam: when a future config sets chart:true, the client can lazy-import uPlot here. -->
  <div class="mt-4 hidden" data-statcalc-chart></div>

  <script is:inline id={configId} type="application/json" set:html={JSON.stringify(config)} />
</section>

<script>
  import './statcalc/client.ts';
</script>
