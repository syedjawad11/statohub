---
import { getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  slug: string;
  variant?: 'page' | 'embed';
}

const { slug, variant = 'embed' } = Astro.props;
const entry = await getEntry('calculators', slug);

if (!entry) {
  throw new Error(`Calculator not found: ${slug}`);
}

type CalculatorData = CollectionEntry<'calculators'>['data'];
type CalculatorInput = CalculatorData['inputs'][number];
type CalculatorOption = NonNullable<CalculatorInput['options']>[number];

const calc = entry.data as CalculatorData;
const instanceId = `statcalc-${slug}-${Math.random().toString(36).slice(2)}`;
const configId = `${instanceId}-config`;
const resultId = `${instanceId}-results`;
const titleId = `${instanceId}-title`;
const isPage = variant === 'page';

const config = {
  engine: calc.engine,
  inputs: calc.inputs,
  precision: calc.precision,
  resultLabel: calc.resultLabel,
  outputLabels: calc.outputLabels ?? {},
  chart: calc.chart,
};
---

<section
  id={instanceId}
  class:list={['statcalc-card', isPage ? 'statcalc-page' : 'statcalc-embed']}
  data-statcalc
  data-config-id={configId}
  aria-labelledby={titleId}
>
  <div class="statcalc-head">
    <span class="pip" aria-hidden="true"></span>
    <span class="statcalc-label">Calculator</span>
    <h2 id={titleId} class="statcalc-title">{calc.title}</h2>
  </div>

  <div class="statcalc-body">
    {isPage && <p class="mb-5 mt-0 text-ink-soft">{calc.description}</p>}
    <form class="space-y-4" data-statcalc-form>
      {
        calc.inputs.map((input: CalculatorInput) => {
          const fieldId = `${instanceId}-${input.name}`;

          return (
            <div>
              <label for={fieldId}>
                {input.label}
              </label>
              {input.type === 'numberList' ? (
                <textarea
                  id={fieldId}
                  name={input.name}
                  rows="5"
                  placeholder={input.placeholder ?? '2, 4, 4, 4, 5, 5, 7, 9'}
                  data-input-type={input.type}
                  class="statcalc-input"
                >
                  {input.default ?? ''}
                </textarea>
              ) : input.type === 'select' ? (
                <select
                  id={fieldId}
                  name={input.name}
                  data-input-type={input.type}
                  class="statcalc-input"
                >
                  {(input.options ?? []).map((option: CalculatorOption) => (
                    <option value={option.value} selected={input.default === option.value}>
                      {option.label}
                    </option>
                  ))}
                </select>
              ) : (
                <input
                  id={fieldId}
                  name={input.name}
                  type="number"
                  inputmode="decimal"
                  value={input.default ?? ''}
                  placeholder={input.placeholder}
                  data-input-type={input.type}
                  class="statcalc-input"
                />
              )}
            </div>
          );
        })
      }

      <button type="submit" class="statcalc-run">
        Compute
      </button>
    </form>

    <div
      id={resultId}
      class="statcalc-results"
      data-statcalc-results
      aria-live="polite"
    >
      <p>Enter values and compute the result.</p>
    </div>

    <!-- Chart seam: when a future config sets chart:true, the client can lazy-import uPlot here. -->
    <div class="mt-4 hidden" data-statcalc-chart></div>
  </div>

  <script is:inline id={configId} type="application/json" set:html={JSON.stringify(config)} />
</section>

<script>
  import './statcalc/client.ts';
</script>
